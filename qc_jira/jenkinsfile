pipeline {
    agent any 
    tools
    {
        nodejs 'nodejs'
    }
    stages{
        stage('Checkout Code to Jenkins from GitHub') 
       {
            steps{
                git branch: 'main', url: 'https://github.com/Omega525/Deployment.git'
       } 
    }
    stage ('Build Artifact')
    {
        steps{
            sh 'npm install'
        }
    }
 }
